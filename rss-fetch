#!/usr/bin/env python3
import sys
import re
import xml.etree.ElementTree as ET
import urllib.request
import concurrent.futures
from datetime import datetime, timezone

EPOCH = datetime(1970, 1, 1, tzinfo=timezone.utc)
NS_MEDIA = "http://search.yahoo.com/mrss/"


def parse_date(s):
    if not s:
        return EPOCH
    s = s.strip()
    for fmt in (
        "%Y-%m-%dT%H:%M:%S%z",
        "%Y-%m-%dT%H:%M:%S.%f%z",
        "%a, %d %b %Y %H:%M:%S %z",
        "%a, %d %b %Y %H:%M:%S GMT",
    ):
        try:
            return datetime.strptime(s, fmt)
        except ValueError:
            pass
    return EPOCH


def strip_html(s):
    s = re.sub(r"<[^>]+>", " ", s)
    s = re.sub(r"&amp;", "&", s)
    s = re.sub(r"&lt;", "<", s)
    s = re.sub(r"&gt;", ">", s)
    s = re.sub(r"&quot;", '"', s)
    s = re.sub(r"&#?\w+;", " ", s)
    return re.sub(r"\s+", " ", s).strip()


def fetch(url):
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "feed-cli/1.0"})
        with urllib.request.urlopen(req, timeout=15) as r:
            return url, r.read(), None
    except Exception as e:
        return url, None, e


def parse_feed(data):
    try:
        root = ET.fromstring(data)
    except ET.ParseError:
        return []

    bare_tag = re.sub(r"\{[^}]+\}", "", root.tag).lower()
    ns_match = re.match(r"\{([^}]+)\}", root.tag)
    ns = ns_match.group(1) if ns_match else ""

    def t(el, tag):
        return (el.findtext(f"{{{ns}}}{tag}") if ns else None) or el.findtext(tag) or ""

    def summary(entry):
        # Atom: <summary> or <content>
        raw = t(entry, "summary") or t(entry, "content")
        # YouTube: <media:group><media:description>
        if not raw:
            group = entry.find(f"{{{NS_MEDIA}}}group")
            if group is not None:
                raw = group.findtext(f"{{{NS_MEDIA}}}description") or ""
        return strip_html(raw)

    items = []

    if bare_tag == "feed":
        channel = t(root, "title")
        entries = root.findall(f"{{{ns}}}entry") if ns else root.findall("entry")
        for entry in entries:
            title = t(entry, "title")
            link_el = entry.find(f"{{{ns}}}link") if ns else entry.find("link")
            if link_el is None and ns:
                link_el = entry.find("link")
            link = link_el.get("href", "") if link_el is not None else ""
            pub = t(entry, "published") or t(entry, "updated")
            items.append((parse_date(pub), channel, title.strip(), link.strip(), summary(entry)))
    else:
        ch = root.find("channel")
        if ch is None:
            return []
        channel = ch.findtext("title", "")
        for item in ch.findall("item"):
            title = item.findtext("title", "")
            link = item.findtext("link", "")
            pub = item.findtext("pubDate", "")
            raw = item.findtext("description") or item.findtext("content") or ""
            items.append((parse_date(pub), channel, title.strip(), link.strip(), strip_html(raw)))

    return items


def main():
    urls = [l.strip() for l in sys.stdin if l.strip() and not l.startswith("#")]
    if not urls:
        sys.exit(0)

    all_items = []
    with concurrent.futures.ThreadPoolExecutor(max_workers=50) as pool:
        for url, data, err in pool.map(fetch, urls):
            if err:
                print(f"# error {url}: {err}")
            else:
                all_items.extend(parse_feed(data))

    all_items.sort(key=lambda x: x[0], reverse=True)

    for date, channel, title, link, blurb in all_items:
        date_str = date.strftime("%Y-%m-%d %H:%M") if date != EPOCH else "?          "
        print(f"{date_str}\t{channel}\t{title}\t{link}\t{blurb}")


if __name__ == "__main__":
    main()
