#!/usr/bin/env bash

while getopts "u:f:" opt; do
    case $opt in
        u) URLS="$OPTARG" ;;
        f) FEEDS="$OPTARG" ;;
    esac
done
shift $((OPTIND - 1))

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/feed"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/feed"
FEEDS="${FEEDS:-${1:-$CACHE_DIR/feeds.tsv}}"
RSSF="$(dirname "$0")/rss-fetch"
URLS="${URLS:-$CONFIG_DIR/rss_urls.txt}"

mkdir -p "$CONFIG_DIR" "$CACHE_DIR"

open_url() {
    local url wid
    read -r url
    if ! command -v surf &>/dev/null; then
        xdg-open "$url"
        return
    fi
    wid=$(xdotool search --class surf 2>/dev/null | head -1)
    if [ -n "$wid" ]; then
        xprop -id "$wid" -f _SURF_URI 8s -set _SURF_URI "$url"
        xdotool windowactivate "$wid"
    else
        WEBKIT_DISABLE_DMABUF_RENDERER=1 surf "$url" &
    fi
}

browse() {
    grep -v '^#' | fzf \
      --delimiter=$'\t' \
      --with-nth=1,2,3 \
      --preview='printf "%b" {5}' \
      --preview-window=right:40%:wrap \
      | cut -f4 | open_url
}

if [ ! -s "$FEEDS" ] || [ -z "$(find "$FEEDS" -mtime -1 2>/dev/null)" ]; then
    "$RSSF" < "$URLS" | tee "$FEEDS" | browse
else
    browse < "$FEEDS"
fi
