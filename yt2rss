#!/usr/bin/env python3
import sys
import re
import urllib.request

RSS_BASE = "https://www.youtube.com/feeds/videos.xml?channel_id="

def extract_channel_id(url):
    m = re.search(r'youtube\.com/channel/([A-Za-z0-9_-]+)', url)
    if m:
        return m.group(1)
    return None

def fetch_channel_id_from_handle(url):
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            html = resp.read().decode("utf-8", errors="replace")
        m = re.search(r'feeds/videos\.xml\?channel_id=([A-Za-z0-9_-]+)', html)
        if m:
            return m.group(1)
    except Exception as e:
        print(f"# error fetching {url}: {e}", file=sys.stderr)
    return None

for line in sys.stdin:
    url = line.strip()
    if not url:
        continue

    channel_id = extract_channel_id(url)

    if not channel_id and re.search(r'youtube\.com/@', url):
        channel_id = fetch_channel_id_from_handle(url)

    if channel_id:
        print(RSS_BASE + channel_id)
    else:
        print(f"# skipped (unrecognized): {url}", file=sys.stderr)
